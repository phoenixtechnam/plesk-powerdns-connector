{
    "name": "plesk/ext-powerdns",
    "description": "Plesk extension for managing DNS zones on external PowerDNS servers",
    "license": "Apache-2.0",
    "type": "plesk-extension",
    "config": {
        "vendor-dir": "src/plib/vendor",
        "allow-plugins": {
            "php-http/discovery": true
        }
    },
    "require": {
        "php": ">=8.0",
        "guzzlehttp/guzzle": "^7.9"
    },
    "require-dev": {
        "phpunit/phpunit": "^9.0 || ^10.0"
    },
    "autoload-dev": {
        "psr-4": {
            "PleskExt\\PowerDNS\\Tests\\": "tests/"
        }
    }
}
